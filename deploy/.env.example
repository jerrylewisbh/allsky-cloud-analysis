# allsky-cloud-analysis — server deployment config template.
#
# Copy to deploy/.env on the server, replace EVERY value below, then run
# ./deploy/server-setup.sh
#
# Do NOT commit deploy/.env — it contains site-specific credentials and
# coordinates that should stay local. This .example file is for structure
# reference only and must remain free of real values before commit.

# === Project location on the server ===
# Full absolute path to where this repo is checked out.
PROJECT_DIR=/home/YOURUSER/allsky-cloud-analysis

# === NAS mounts (must exist before running setup) ===
# Local mount points where the allsky JPGs and thermal BMP+JSON pairs live.
# Day-dirs are expected at:
#   ${NAS_ALLSKY_PATH}/images/YYYYMMDD/
#   ${NAS_THERMAL_PATH}/${NAS_THERMAL_UUID}/exposures/YYYYMMDD/
NAS_ALLSKY_PATH=/mnt/allsky_images
NAS_THERMAL_PATH=/mnt/astro_image_thermal
NAS_THERMAL_UUID=ccd_REPLACE_WITH_YOUR_THERMAL_DEVICE_UUID

# === Postgres (already running via your allsky-cloud-analysis docker-compose) ===
# PG_PASS in particular is sensitive. Generate a strong random password and
# update both this file AND the docker-compose env that started the db.
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=cloud_analysis
PG_USER=allsky
PG_PASS=CHANGEME_USE_A_STRONG_PASSWORD

# === Labeling UI binding ===
# STREAMLIT_HOST should be the LAN IP you want to bind to. Use 127.0.0.1 to
# limit access to the server itself; use a LAN IP (e.g. 10.0.0.X) to expose
# on your home network. NEVER use 0.0.0.0 without putting auth in front.
STREAMLIT_HOST=127.0.0.1
STREAMLIT_PORT=8501

# === Site coordinates ===
# Sensor lat/lon in decimal degrees. Used by GOES sampling, METAR distance
# computation, and ephemeris. Be aware that committing exact home coordinates
# to a public repo is equivalent to publishing your home address — set them
# in your local .env only.
SITE_LAT=
SITE_LON=

# === METAR stations (Iowa State ASOS station IDs) ===
# Primary = closest reporting station. Secondary = cross-check from a
# different microclimate if useful. Station lat/lon are public airport data;
# safe to keep these as your-airport values.
METAR_STATION_PRIMARY=
METAR_STATION_PRIMARY_LAT=
METAR_STATION_PRIMARY_LON=
METAR_STATION_SECONDARY=
METAR_STATION_SECONDARY_LAT=
METAR_STATION_SECONDARY_LON=

# === GOES products to fetch ===
# ACMC=cloud mask, ACTPC=cloud-top phase, ACHAC=cloud-top height.
# COD products are algorithmically masked at high satellite-zenith sites
# (e.g. >50°N); leave out unless you've verified your site is covered.
GOES_PRODUCTS="ACMC ACTPC ACHAC"

# === Filename timezone ===
# indi-allsky writes frame filenames (ccd1_YYYYMMDD_HHMMSS) in the camera
# host's local wall-clock time, NOT UTC. The GOES/METAR/ephemeris joiners
# need this to convert correctly before matching against UTC observations.
# Use an IANA name (not a fixed offset) so DST transitions don't silently
# corrupt half the year.
#   Examples: America/Edmonton, America/Sao_Paulo, Europe/London, Asia/Tokyo
ALLSKY_LOCAL_TZ=UTC

# === Logging ===
LOG_DIR=/var/log/allsky-cloud-analysis
